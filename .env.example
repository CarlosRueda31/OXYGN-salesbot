# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google Sheet ID (from the spreadsheet URL)
# Example: https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Service Account credentials (paste the full JSON content)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# Alternative: path to credentials file (for local development)
# GOOGLE_CREDENTIALS_FILE=credentials.json
